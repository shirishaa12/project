{
  "name": "karnataka-ev-connect",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n api,web -c green,cyan \"tsx watch server/index.ts\" \"vite --host 127.0.0.1\"",
    "build": "tsc -b && vite build",
    "start": "tsx server/index.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "cookie-parser": "^1.4.7",
    "express": "^5.2.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.468.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-leaflet": "^5.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5.0.5",
    "@types/leaflet": "^1.9.16",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "jsdom": "^25.0.1",
    "tsx": "^4.21.0",
    "typescript": "~5.7.2",
    "vite": "^8.1.4",
    "vitest": "^2.1.8"
  }
}
